# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/precision_genomics"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Python ML Service
ML_SERVICE_URL="http://localhost:8000"

# MCP Server (if running externally)
MCP_SERVER_URL="http://localhost:8080"

# Anthropic
ANTHROPIC_API_KEY=""

# Auth — inbound (public web edge). When REQUIRE_AUTH=true, /api/* requires an
# x-api-key in API_KEYS (comma-separated) or a Bearer JWT signed with JWT_SECRET.
# Left "false" for local dev; set "true" in production.
JWT_SECRET=""
API_KEYS=""
REQUIRE_AUTH="false"

# Auth — internal control plane (gap #8). Shared service token sent to the Go
# controller and the Python ml_service as X-Service-Token. SERVER-ONLY: do NOT
# prefix with NEXT_PUBLIC_. Leave empty locally to run both services in bypass;
# set it in production to match the controller's and ml_service's value.
SERVICE_AUTH_TOKEN=""

# App
NEXT_PUBLIC_APP_NAME="CLUE"
