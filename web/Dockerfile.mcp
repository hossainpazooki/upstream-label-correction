# Dockerfile.mcp — MCP server (TypeScript, Node)
# Builds the standalone MCP server from web/ source.
# Shares src/, prisma/, and node_modules with the Next.js app.

FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json ./
RUN npm install

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY package.json tsconfig.json ./
COPY prisma/ ./prisma/
COPY src/ ./src/
RUN npx prisma generate

EXPOSE 8080
ENV PORT=8080

CMD ["npx", "tsx", "src/mcp/server.ts"]
