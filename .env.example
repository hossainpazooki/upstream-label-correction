# Application
APP_NAME="CLUE"
ENVIRONMENT=local
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/precision_genomics

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (LLM)
# ANTHROPIC_API_KEY=

# Data paths
DATA_DIR=data
RAW_DATA_DIR=data/raw

# ML settings
RANDOM_STATE=42
CV_FOLDS=10
N_ESTIMATORS=500

# Auth
REQUIRE_AUTH=false
# API_KEYS=key1,key2

# Feature flags
ENABLE_FEATURE_STORE=true

# GCP Workflows
# WORKFLOWS_PROJECT=your-gcp-project-id
# WORKFLOWS_LOCATION=us-central1
# WORKFLOWS_ACTIVITY_SERVICE_URL=https://precision-genomics-worker-xxxxx-uc.a.run.app
# WORKFLOWS_BIOMARKER_DISCOVERY_ID=precision-genomics-biomarker-discovery
# WORKFLOWS_SAMPLE_QC_ID=precision-genomics-sample-qc
# WORKFLOWS_PROMPT_OPTIMIZATION_ID=precision-genomics-prompt-optimization

# --- GCP Settings (optional, leave unset for local dev) ---
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GCS_DATA_BUCKET=your-project-genomics-data
# GCS_MODEL_BUCKET=your-project-genomics-models
# VERTEX_AI_STAGING_BUCKET=your-project-genomics-models
# VERTEX_AI_EXPERIMENT_NAME=precision-genomics
# CLOUD_SQL_INSTANCE=your-project:us-central1:precision-genomics-pg
# USE_SECRET_MANAGER=false
# PERSIST_MODELS=false
# REGISTER_VERTEX_MODELS=false
